{
  "manifest_version": 3,
  "name": "Atlas",
  "version": "1.7",
  "description": "Adds buttons on the UWorld results page to open the matching AnKing cards in Anki, via a live tag search, shows images of all available resources",
  "key": "",
  "permissions": ["storage"],
  "host_permissions": ["http://127.0.0.1:8765/*"],
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "background": { "service_worker": "background.js" },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Atlas",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["https://*.uworld.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle",
      "all_frames": true
    }
  ]
}
